    {
      "parameters": {
        "jsCode": "const text = $json.message.text || \"\";\n\nfunction removeAccents(str) {\n  return str.normalize(\"NFD\").replace(/[\\u0300-\\u036f]/g, \"\");\n}\n\nlet cleaned = text.trim();\ncleaned = removeAccents(cleaned);\ncleaned = cleaned.toLowerCase();\n\nlet cityQuery = \"\";\n\nif (cleaned.includes(\",\")) {\n  const parts = cleaned.split(\",\").map(p => p.trim());\n\n  if (parts.length === 2) {\n    cityQuery = `${parts[0]},${parts[1]},br`;\n  }\n\n  if (parts.length === 3) {\n    cityQuery = `${parts[0]},${parts[1]},${parts[2]}`;\n  }\n\n} else {\n  cityQuery = `${cleaned},br`;\n}\n\nreturn [{\n  chat_id: $json.message.chat.id,\n  city_raw: text,\n  queue: cityQuery\n}];"
      },
      "id": "6a45e941-c406-42bb-af4d-67cabf973530",
      "name": "Input Processor",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -656,
        160
      ]
    },
    {
