        "telegramApi": {
          "id": "sOfrVFd2lKR3k3q6",
          "name": "Telegram account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "const body = $json.body;\n\nconst city = body.name;\nconst temp = Math.round(body.main.temp);\nconst feels = Math.round(body.main.feels_like);\nconst humidity = body.main.humidity;\nconst description = body.weather[0].description;\n\nreturn [{\n  chat_id: $node[\"Input Processor\"].json.chat_id,\n  city,\n  temp,\n  feels,\n  humidity,\n  description,\n  fallback_message: `🌤️ Clima em <b>${city}</b>:\\n\\nTemperatura: ${temp}°C\\nSensação térmica: ${feels}°C\\nCondição: ${description}\\nUmidade: ${humidity}%`\n}];"
      },
      "id": "a392ca69-8632-48d0-b10d-8aceda433490",
      "name": "Round Temperature",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -32,
        -32
      ]
    },
    {
      "parameters": {
        "jsCode": "const geminiText =\n  $json.text ||\n  $json.output ||\n  $json.candidates?.[0]?.content?.parts?.[0]?.text ||\n  null;\n\nconst city = $node[\"Round Temperature\"].json.city;\nconst chat_id = $node[\"Round Temperature\"].json.chat_id;\nconst fallback = $node[\"Round Temperature\"].json.fallback_message;\n\nif (geminiText) {\n  return [\n    {\n      chat_id,\n      message: `🌤️ <b>${city}</b>\\n\\n${geminiText}`,\n    },\n  ];\n}\n\nreturn [\n  {\n    chat_id,\n    message: fallback,\n  },\n];"
      },
      "id": "f37b9d16-5f3c-47fe-b0f0-bf890cbbbedc",
